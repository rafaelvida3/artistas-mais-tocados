{
    "config": {
        "sort-packages": true
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpunit/phpunit": "^13.1"
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "lint": "php-cs-fixer fix --dry-run --diff --verbose",
        "format": "php-cs-fixer fix --verbose"
    }
}
