{
    "config": {
        "sort-packages": true
    },
    "require": {
        "ext-intl": "*"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1"
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml",
        "lint": "php-cs-fixer fix --dry-run --diff --verbose",
        "format": "php-cs-fixer fix --verbose",
        "analyse": "phpstan analyse --configuration=phpstan.neon.dist"
    }
}
